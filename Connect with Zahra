.hero-intro { font-size: 1.05rem; color: #3a3530; line-height: 1.8; max-width: 52ch; margin-bottom: 2.5rem; font-weight: 300; }
.hero-cta { display: inline-flex; align-items: center; gap: 0.75rem; background: var(–ink); color: var(–cream); padding: 0.85rem 2rem; font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; font-weight: 500; transition: background 0.25s, gap 0.25s; }
.hero-cta:hover { background: var(–gold); gap: 1.25rem; }
.hero-stats { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5px; background: var(–warm); border: 1.5px solid var(–warm); }
.stat-card { background: var(–cream); padding: 2.25rem 2rem; transition: background 0.25s; }
.stat-card:hover { background: #f2ede4; }
.stat-number { font-family: ‘Cormorant Garamond’, serif; font-size: 2.8rem; font-weight: 300; color: var(–gold); line-height: 1; margin-bottom: 0.4rem; }
.stat-label { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(–muted); font-weight: 500; }

section { padding: 6rem 4rem; }
.section-label { font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(–gold); font-weight: 500; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem; }
.section-label::before { content: ‘’; display: block; width: 1.5rem; height: 1px; background: var(–gold); }
