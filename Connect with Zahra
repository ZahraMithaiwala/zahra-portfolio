nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; padding: 1.25rem 4rem; background: rgba(249,246,240,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(–warm); }
