.case-block h3 { font-family: ‘Cormorant Garamond’, serif; font-size: 1.2rem; font-weight: 400; margin-bottom: 0.75rem; line-height: 1.4; }
.case-block p { font-size: 0.88rem; color: #4a4540; line-height: 1.75; font-weight: 300; }
.case-result { background: #f2ede4; }
.case-result .case-block-label { color: var(–ink); }
.case-result p { font-weight: 400; color: var(–ink); }

/* HOW I WORK */
#how { background: #f4efe6; }
.how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.how-card { background: var(–cream); padding: 2.5rem 2rem; border-bottom: 3px solid transparent; transition: border-color 0.3s, transform 0.3s; }
.how-card:hover { border-color: var(–gold); transform: translateY(-4px); }
.how-icon { font-family: ‘Cormorant Garamond’, serif; font-size: 2.5rem; font-weight: 300; color: var(–gold); margin-bottom: 1.25rem; display: block; }
.how-card h3 { font-family: ‘Cormorant Garamond’, serif; font-size: 1.3rem; font-weight: 400; margin-bottom: 0.75rem; }
.how-card p { font-size: 0.88rem; color: #5a5550; line-height: 1.8; font-weight: 300; }

/* STRENGTHS */
#strengths { background: var(–cream); }
.strengths-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5px; background: var(–warm); border: 1.5px solid var(–warm); }
.strength-item { background: var(–cream); padding: 2rem 1.75rem; transition: background 0.25s; }
.strength-item:hover { background: #f0ebe0; }
.strength-num { font-family: ‘Cormorant Garamond’, serif; font-size: 1rem; color: var(–gold); margin-bottom: 0.75rem; display: block; }
.strength-item h3 { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.5rem; }
