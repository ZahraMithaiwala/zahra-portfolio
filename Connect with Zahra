.hero-text { position: relative; z-index: 1; }
.hero-eyebrow { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(–gold); font-weight: 500; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; }
.hero-eyebrow::before { content: ‘’; display: block; width: 2rem; height: 1px; background: var(–gold); }
h1 { font-family: ‘Cormorant Garamond’, serif; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 300; line-height: 1.1; letter-spacing: -0.01em; margin-bottom: 1.75rem; }
